# ── Base de datos MySQL (Railway genera estas variables automáticamente) ──────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mapa_procesos
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_aqui

# ── Puerto del servidor Express ───────────────────────────────────────────────
PORT=3001

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production
